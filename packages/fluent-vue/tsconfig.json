{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2019",
    "jsx": "preserve",
    "lib": ["esnext", "dom"],
    "rootDir": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": false,
    "noUnusedLocals": true,
    "declaration": true,
    "outDir": "dist",
    "removeComments": false,
    "isolatedDeclarations": true
  },
  "include": ["src"]
}
