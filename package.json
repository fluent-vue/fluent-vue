{
  "name": "fluent-vue-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "ls-lint": "pnpm -r ls-lint",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish --provenance"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@changesets/cli": "^2.29.8",
    "@changesets/get-github-info": "^0.7.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.ts?(x)": "eslint --fix",
    "*.md": "eslint --fix",
    "*.json": "eslint --fix",
    "*.yml": "eslint --fix"
  }
}
